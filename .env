# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Price ID for the $4.99/month premium plan
# Create at: https://dashboard.stripe.com/products → Add product → Monthly $4.99
VITE_STRIPE_PREMIUM_PRICE_ID=price_your-price-id

# Payment Link URL (easiest no-server option)
# Create at: https://dashboard.stripe.com/payment-links → New → select your price
# Add success URL param: https://friendusapp.com/?upgraded=1
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link
